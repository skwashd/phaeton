{
  "name": "webhook_to_dynamodb",
  "nodes": [
    {
      "id": "b2c3d4e5-0002-4000-8000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "/api/data",
        "responseMode": "onReceived"
      }
    },
    {
      "id": "b2c3d4e5-0002-4000-8000-000000000002",
      "name": "DDBPut",
      "type": "n8n-nodes-base.awsDynamoDB",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "resource": "item",
        "operation": "create",
        "tableName": "MyTable",
        "additionalFields": {}
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [{"node": "DDBPut", "type": "main", "index": 0}]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
